{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "cf-claude-code",
	"main": "./src/worker/index.ts",
	"compatibility_date": "2025-10-08",
	"compatibility_flags": ["nodejs_compat"],
	"observability": {
		"enabled": true
	},
	"d1_databases": [
		{
			"binding": "RUNTIME_DB",
			"database_name": "cf-claude-code",
			"database_id": "f35a569d-a678-4ca7-aedd-c44f90f00e31"
		}
	],
	"r2_buckets": [
		{
			"binding": "RUNTIME_BUCKET",
			"bucket_name": "cf-claude-code-runtime"
		}
	],
	"upload_source_maps": true,
	"assets": {
		"directory": "./dist/client",
		"not_found_handling": "single-page-application"
	}
}
